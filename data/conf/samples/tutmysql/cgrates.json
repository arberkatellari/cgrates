"stor_db": {
	"db_password": "CGRateS.org",
},


"rals": {
	"enabled": true,
	"thresholds_conns": ["*internal"],
	"max_increments":3000000,
},


"schedulers": {
	"enabled": true,
	"cdrs_conns": ["*internal"],
	"stats_conns": ["*internal"],
},


"cdrs": {
	"enabled": true,
	"chargers_conns":["*internal"],
},


"attributes": {
	"enabled": true,
	"stats_conns": ["*internal"],
	"resources_conns": ["*internal"],
	"apiers_conns": ["*internal"]
},


"chargers": {
	"enabled": true,
	"attributes_conns": ["*internal"],
},


"resources": {
	"enabled": true,
	"store_interval": "1s",
	"thresholds_conns": ["*internal"]
},


"stats": {
	"enabled": true,
	"store_interval": "1s",
	"thresholds_conns": ["*internal"],
},


"thresholds": {
	"enabled": true,
	"store_interval": "1s",
},


"routes": {
	"enabled": true,
	"prefix_indexed_fields":["*req.Destination"],
	"stats_conns": ["*internal"],
	"resources_conns": ["*internal"],
	"rals_conns": ["*internal"],
},


"sessions": {
	"enabled": true,
	"routes_conns": ["*internal"],
	"resources_conns": ["*internal"],
	"attributes_conns": ["*internal"],
	"rals_conns": ["*internal"],
	"cdrs_conns": ["*internal"],
	"chargers_conns": ["*internal"],
},


"migrator":{
	"out_stordb_password": "CGRateS.org",
	"users_filters":["Account"],
},


"apiers": {
	"enabled": true,
	"scheduler_conns": ["*internal"],
},


"filters": {
	"stats_conns": ["*internal"],
	"resources_conns": ["*internal"],
	"apiers_conns": ["*internal"],
},


}
